/* Theme: {{ meta.name }}
 * Generated by theme switcher — do not edit directly.
 * Edit the template at modules/theme/templates/rofi/theme.rasi.j2
 */

* {
    font:                        "MesloLGS Nerd Font Mono 13";

    bg:                          rgba ( {{ base | to_rgb }}, 92 % );
    bg-solid:                    {{ base }};
    bg-alt:                      {{ surface0 }};
    bg-selected:                 {{ surface1 }};

    fg:                          {{ text }};
    fg-alt:                      {{ subtext0 }};
    fg-disabled:                 {{ overlay0 }};

    accent:                      {{ mauve }};
    accent-border:               rgba ( {{ mauve | to_rgb }}, 30 % );
    urgent:                      {{ red }};

    background-color:            transparent;
    text-color:                  @fg;

    margin:                      0;
    padding:                     0;
    spacing:                     0;
}

window {
    location:                    center;
    width:                       480px;
    border-radius:               12px;
    border:                      2px solid;
    border-color:                @accent-border;
    background-color:            @bg;
}

mainbox {
    padding:                     12px;
    spacing:                     12px;
}

inputbar {
    padding:                     10px 16px;
    spacing:                     10px;
    border-radius:               8px;
    background-color:            @bg-alt;
    children:                    [ icon-search, entry ];
}

icon-search {
    expand:                      false;
    filename:                    "search";
    size:                        20px;
    vertical-align:              0.5;
    text-color:                  @fg-disabled;
}

entry {
    placeholder:                 "Search...";
    placeholder-color:           @fg-disabled;
    text-color:                  @fg;
}

message {
    margin:                      0 4px;
}

textbox {
    padding:                     8px;
    border-radius:               8px;
    background-color:            @bg-alt;
    text-color:                  @fg-alt;
}

listview {
    lines:                       8;
    columns:                     1;
    fixed-height:                false;
    spacing:                     4px;
}

element {
    padding:                     10px 16px;
    spacing:                     12px;
    border-radius:               8px;
    cursor:                      pointer;
}

element normal.normal {
    text-color:                  @fg;
}

element normal.active {
    text-color:                  @accent;
}

element normal.urgent {
    text-color:                  @urgent;
}

element selected.normal {
    background-color:            @bg-selected;
    text-color:                  @accent;
}

element selected.active {
    background-color:            @bg-selected;
    text-color:                  @accent;
}

element selected.urgent {
    background-color:            @urgent;
    text-color:                  @bg-solid;
}

element-icon {
    size:                        24px;
    cursor:                      inherit;
    vertical-align:              0.5;
}

element-text {
    cursor:                      inherit;
    vertical-align:              0.5;
    text-color:                  inherit;
}

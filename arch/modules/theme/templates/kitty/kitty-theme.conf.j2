# The basic colors
foreground              {{ text | upper_hex }}
background              {{ base | upper_hex }}
selection_foreground    {{ base | upper_hex }}
selection_background    {{ rosewater | upper_hex }}

# Cursor colors
cursor                  {{ rosewater | upper_hex }}
cursor_text_color       {{ base | upper_hex }}

# URL underline color when hovering with mouse
url_color               {{ lavender | upper_hex }}

# Kitty window border colors
active_border_color     {{ ui.accent | upper_hex }}
inactive_border_color   {{ overlay2 | upper_hex }}
bell_border_color       {{ red | upper_hex }}

# Tab bar colors

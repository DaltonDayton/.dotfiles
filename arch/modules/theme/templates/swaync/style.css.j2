/* Theme: {{ meta.name }}
 * Generated by theme switcher — do not edit directly.
 * Edit the template at modules/theme/templates/swaync/style.css.j2
 */

/* ============================================
 * NOTIFICATION POPUPS
 * ============================================ */

.notification-row {
  outline: none;
}

.notification-row:focus,
.notification-row:hover {
  background: transparent;
}

.notification {
  border-radius: 12px;
  margin: 8px 12px;
  box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.5),
              0 1px 4px 0 rgba(0, 0, 0, 0.3);
  padding: 0;
  transition: all 250ms ease;
}

.notification:hover {
  box-shadow: 0 6px 20px 0 rgba(0, 0, 0, 0.55),
              0 0 16px 0 alpha({{ mauve }}, 0.12);
}

.notification-content {
  background: alpha({{ base }}, 0.94);
  padding: 14px 16px;
  border-radius: 12px;
  border: 2px solid alpha({{ mauve }}, 0.3);
  border-left: 4px solid {{ mauve }};
}

.notification-content:hover {
  border-color: alpha({{ lavender }}, 0.5);
  border-left-color: {{ lavender }};
}

/* Urgency: critical */
.critical .notification-content {
  background: alpha({{ base }}, 0.96);
  border-color: alpha({{ red }}, 0.5);
  border-left-color: {{ red }};
  border-left-width: 4px;
}

.critical .notification-content:hover {
  border-color: {{ red }};
  border-left-color: {{ red }};
}

.critical .summary {
  color: {{ red }};
}

/* Urgency: low */
.low .notification-content {
  border-color: alpha({{ surface2 }}, 0.4);
  border-left-color: {{ surface2 }};
}

.low .summary {
  color: {{ subtext0 }};
}

/* Notification text */
.summary {
  font-family: "MesloLGS Nerd Font Mono Bold";
  font-size: 14px;
  font-weight: bold;
  color: {{ mauve }};
  margin-bottom: 4px;
}

.body {
  font-family: "MesloLGS Nerd Font Mono";
  font-size: 12px;
  color: {{ subtext1 }};
  line-height: 1.4;
}

.time {
  font-family: "MesloLGS Nerd Font Mono";
  font-size: 10px;
  color: {{ sapphire }};
  margin-right: 14px;
}

/* Notification image/icon */
.image {
  border-radius: 10px;
  margin-right: 14px;
  box-shadow: 0 1px 4px 0 rgba(0, 0, 0, 0.3);
}

/* App icon in notification */
.notification-default-action .image {
  margin-top: 2px;
}

/* Close button */
.close-button {
  background: alpha({{ mauve }}, 0.15);
  color: {{ mauve }};
  border-radius: 50%;
  padding: 2px;
  margin: 6px;
  min-width: 22px;
  min-height: 22px;
  border: 1px solid alpha({{ mauve }}, 0.3);
  transition: all 200ms ease;
}

.close-button:hover {
  background: {{ pink }};
  color: {{ base }};
  border-color: {{ pink }};
}

/* Action buttons within notifications */
.notification-action {
  background: alpha({{ surface0 }}, 0.8);
  color: {{ subtext1 }};
  border-radius: 8px;
  border: 1px solid alpha({{ mauve }}, 0.25);
  margin: 4px 2px 2px 2px;
  padding: 6px 12px;
  font-family: "MesloLGS Nerd Font Mono";
  font-size: 11px;
  transition: all 200ms ease;
}

.notification-action:hover {
  background: alpha({{ mauve }}, 0.15);
  color: {{ mauve }};
  border-color: alpha({{ mauve }}, 0.5);
}

.notification-action:first-child {
  margin-left: 0;
}

.notification-action:last-child {
  margin-right: 0;
}

/* ============================================
 * CONTROL CENTER (notification panel)
 * ============================================ */

.control-center {
  background: alpha({{ crust }}, 0.95);
  border-radius: 16px;
  border: 2px solid alpha({{ mauve }}, 0.2);
  margin: 12px;
  padding: 12px;
  box-shadow: 0 8px 24px 0 rgba(0, 0, 0, 0.6);
}

/* Title widget */
.widget-title {
  color: {{ mauve }};
  font-family: "MesloLGS Nerd Font Mono Bold";
  font-size: 16px;
  font-weight: bold;
  margin: 8px;
}

.widget-title > button {
  background: alpha({{ mauve }}, 0.1);
  color: {{ text }};
  border-radius: 8px;
  padding: 4px 12px;
  border: 1px solid alpha({{ mauve }}, 0.25);
  font-family: "MesloLGS Nerd Font Mono";
  font-size: 12px;
  transition: all 200ms ease;
}

.widget-title > button:hover {
  background: alpha({{ mauve }}, 0.2);
  color: {{ mauve }};
  border-color: alpha({{ mauve }}, 0.5);
}

/* DND toggle */
.widget-dnd {
  margin: 8px;
  font-family: "MesloLGS Nerd Font Mono";
  color: {{ subtext1 }};
}

.widget-dnd > switch {
  border-radius: 12px;
  background: {{ surface0 }};
  border: 2px solid {{ surface1 }};
}

.widget-dnd > switch:checked {
  background: {{ pink }};
  border-color: {{ pink }};
}

.widget-dnd > switch slider {
  background: {{ text }};
  border-radius: 50%;
}

/* MPRIS widget (media controls) */
.widget-mpris {
  background: alpha({{ surface0 }}, 0.6);
  border-radius: 12px;
  padding: 8px;
  margin: 8px;
  border: 1px solid alpha({{ sapphire }}, 0.25);
}

.widget-mpris-player {
  padding: 8px;
}

.widget-mpris-title {
  font-family: "MesloLGS Nerd Font Mono Bold";
  font-weight: bold;
  font-size: 13px;
  color: {{ text }};
}

.widget-mpris-subtitle {
  font-family: "MesloLGS Nerd Font Mono";
  font-size: 11px;
  color: {{ subtext0 }};
}

.widget-mpris > box > button {
  background: transparent;
  color: {{ sapphire }};
  border: none;
  border-radius: 8px;
  padding: 4px;
  min-width: 28px;
  min-height: 28px;
  transition: all 200ms ease;
}

.widget-mpris > box > button:hover {
  background: alpha({{ sapphire }}, 0.15);
  color: {{ sky }};
}

/* Button grid */
.widget-buttons-grid {
  margin: 8px;
}

.widget-buttons-grid > flowbox > flowboxchild > button {
  background: {{ surface0 }};
  color: {{ subtext1 }};
  border-radius: 8px;
  padding: 8px 12px;
  margin: 4px;
  border: 1px solid {{ surface1 }};
  font-family: "MesloLGS Nerd Font Mono";
  font-size: 12px;
  transition: all 200ms ease;
}

.widget-buttons-grid > flowbox > flowboxchild > button:hover {
  background: {{ surface1 }};
  color: {{ text }};
  border-color: alpha({{ mauve }}, 0.3);
}

.widget-buttons-grid > flowbox > flowboxchild > button.toggle:checked {
  background: {{ mauve }};
  color: {{ base }};
  border-color: {{ mauve }};
}

/* Notifications within control center */
.control-center .notification-row .notification {
  margin: 4px 0;
  box-shadow: none;
}

.control-center .notification-row .notification-content {
  background: alpha({{ base }}, 0.8);
  border: 1px solid alpha({{ mauve }}, 0.15);
  border-left: 3px solid {{ mauve }};
}

.control-center .notification-row .notification-content:hover {
  border-color: alpha({{ lavender }}, 0.35);
  border-left-color: {{ lavender }};
}

.control-center .notification-row .critical .notification-content {
  border-color: alpha({{ red }}, 0.3);
  border-left-color: {{ red }};
}

.control-center .notification-row .low .notification-content {
  border-color: alpha({{ surface2 }}, 0.3);
  border-left-color: {{ surface2 }};
}

/* Scrollbar in control center */
scrollbar {
  border-radius: 8px;
}

scrollbar slider {
  background: alpha({{ mauve }}, 0.2);
  border-radius: 8px;
  min-width: 4px;
  min-height: 20px;
}

scrollbar slider:hover {
  background: alpha({{ mauve }}, 0.4);
}

/* ============================================
 * NOTIFICATION GROUP HEADERS
 * ============================================ */

.notification-group-headers {
  font-family: "MesloLGS Nerd Font Mono Bold";
  font-weight: bold;
  color: {{ lavender }};
  font-size: 12px;
  margin: 4px 8px;
}

/* ============================================
 * BLANK WINDOW (behind control center)
 * ============================================ */

.blank-window {
  background: alpha(black, 0.15);
}
